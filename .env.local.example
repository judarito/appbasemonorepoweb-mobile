# =============================================================================
# BaseForge SaaS - Variables de Entorno de Desarrollo Local
# =============================================================================

# Entorno general
NODE_ENV=development
PORT=3000

# Base de datos local (PostgreSQL en Docker)
DB_HOST=localhost
DB_PORT=5432
DB_USER=baseforge_user
DB_PASSWORD=baseforge_password
DB_NAME=baseforge_db
DB_SSL=false
DATABASE_URL=postgresql://baseforge_user:baseforge_password@localhost:5432/baseforge_db?sslmode=disable

# Autenticación (JWT)
JWT_ACCESS_SECRET=local-secret-access-token-key-change-me
JWT_REFRESH_SECRET=local-secret-refresh-token-key-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# URLs base
API_BASE_URL=http://localhost:3000/api/v1
WEB_BASE_URL=http://localhost:5173

# Logger
LOG_LEVEL=debug
