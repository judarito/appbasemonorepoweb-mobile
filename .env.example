# =============================================================================
# BaseForge SaaS - Variables de Entorno (Plantilla)
# =============================================================================

# Entorno general
NODE_ENV=development # local, development, staging, production
PORT=3000

# Base de datos (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=baseforge_user
DB_PASSWORD=baseforge_password
DB_NAME=baseforge_db
DB_SSL=false

# Autenticación (JWT)
# Puedes generar claves seguras usando: openssl rand -base64 32
JWT_ACCESS_SECRET=super-secret-access-token-key-change-me
JWT_REFRESH_SECRET=super-secret-refresh-token-key-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# URLs base
API_BASE_URL=http://localhost:3000/api/v1
WEB_BASE_URL=http://localhost:5173

# Logger
LOG_LEVEL=info # fatal, error, warn, info, debug, trace
